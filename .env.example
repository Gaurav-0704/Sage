# Sage — AI-powered School ERP
# Copy this file to .env and fill in your values.

# Required: get your key at console.anthropic.com
ANTHROPIC_API_KEY=your_key_here

# Optional: override the default model
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Optional: JWT secret — CHANGE THIS in production
SECRET_KEY=change-me-in-production

# ---------------- Email notifications (TIER 1d) ----------------
# Delivery priority: Resend (if RESEND_API_KEY set) → SMTP → console log.
# Leave all blank to just log notifications (still stored + auditable).

# Resend (https://resend.com) — simplest for production:
# RESEND_API_KEY=re_xxxxxxxx
# FROM_EMAIL=noreply@yourschool.com

# …or classic SMTP (e.g. Gmail app password, Mailgun, etc.):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASS=your_app_password
# FROM_EMAIL=you@example.com

# ---------------- Online fee payment — Razorpay (TIER 2) ----------------
# Leave blank to disable online payment (manual fee entry still works).
# Test-mode keys (rzp_test_...) work as-is from the Razorpay dashboard.
# RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
# RAZORPAY_KEY_SECRET=your_key_secret
